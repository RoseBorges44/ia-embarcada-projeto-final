    "test_loss, test_acc = model.evaluate(test_ds, verbose=2)\n",
    "print(f'\\nAcurácia no test set (float32): {test_acc*100:.2f}%')\n",
    "\n",
    "# Matriz de confusão\n",
    "y_true, y_pred = [], []\n",
    "for features, label in test_ds:\n",
    "    preds = model.predict(features, verbose=0).argmax(axis=1)\n",
    "    y_true.extend(label.numpy())\n",
    "    y_pred.extend(preds)\n",
    "\n",
    "import itertools\n",
    "cm = tf.math.confusion_matrix(y_true, y_pred).numpy()\n",
    "cm_norm = cm / cm.sum(axis=1, keepdims=True)\n",
    "\n",
    "plt.figure(figsize=(7, 6))\n",
    "plt.imshow(cm_norm, cmap='Blues', vmin=0, vmax=1)\n",
    "plt.colorbar(label='proporção')\n",
    "plt.xticks(range(NUM_CLASSES), LABELS, rotation=45)\n",
    "plt.yticks(range(NUM_CLASSES), LABELS)\n",
    "for i, j in itertools.product(range(NUM_CLASSES), range(NUM_CLASSES)):\n",
    "    txt = f'{cm[i,j]}\\n{cm_norm[i,j]*100:.0f}%'\n",
    "    color = 'white' if cm_norm[i, j] > 0.5 else 'black'\n",
    "    plt.text(j, i, txt, ha='center', va='center', color=color, fontsize=9)\n",
    "plt.xlabel('predição'); plt.ylabel('real')\n",
    "plt.title(f'Matriz de confusão — test set (acc {test_acc*100:.1f}%)')\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
