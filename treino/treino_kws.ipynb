   "source": [
    "import os\n",
    "import numpy as np\n",
    "import tensorflow as tf\n",
    "import tensorflow_datasets as tfds\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "print('TensorFlow:', tf.__version__)\n",
    "print('GPU disponível:', len(tf.config.list_physical_devices('GPU')) > 0)\n",
    "\n",
    "# Reprodutibilidade\n",
    "SEED = 42\n",
    "np.random.seed(SEED)\n",
    "tf.random.set_seed(SEED)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "pzaN-HhaWtkM"
   },
   "source": [
    "## 2. Configuração\n",
    "\n",
    "Pra mudar palavras alvo, edite `TARGET_WORDS`. Tem que coincidir com os labels no firmware (`firmware/inference.h`)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "e8KchNZxWtkN",
    "outputId": "acc96bfb-3130-4e88-ddc3-87bb8a2093dc"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "6 classes: ['happy', 'yes', 'no', 'stop', 'silence', 'unknown']\n",
      "Feature shape: (49, 40, 1)\n"
     ]
    }
   ],
   "source": [
    "# Palavras-alvo (do Google Speech Commands)\n",
    "TARGET_WORDS = ['happy', 'yes', 'no', 'stop']\n",
    "\n",
    "# Classes finais (na mesma ordem do firmware)\n",
    "#   índice 0..3 = palavras-alvo\n",
    "#   índice 4   = silence (ruído quase nulo)\n",
    "#   índice 5   = unknown (qualquer outra palavra)\n",
    "LABELS = TARGET_WORDS + ['silence', 'unknown']\n",
    "NUM_CLASSES = len(LABELS)\n",
    "print(f'{NUM_CLASSES} classes:', LABELS)\n",
    "\n",
    "# Parâmetros de áudio (precisam casar EXATAMENTE com firmware/features.h)\n",
    "SAMPLE_RATE   = 16000\n",
    "CLIP_DURATION = 1.0          # 1 segundo\n",
    "CLIP_SAMPLES  = int(SAMPLE_RATE * CLIP_DURATION)\n",
    "\n",
    "WINDOW_SIZE_MS = 30          # janela da FFT\n",
    "WINDOW_STRIDE_MS = 20        # passo entre janelas\n",
    "WINDOW_SIZE_SAMPLES   = int(SAMPLE_RATE * WINDOW_SIZE_MS / 1000)    # 480\n",
    "WINDOW_STRIDE_SAMPLES = int(SAMPLE_RATE * WINDOW_STRIDE_MS / 1000)  # 320\n",
    "\n",
    "N_MEL_BINS = 40\n",
    "N_FRAMES   = 1 + (CLIP_SAMPLES - WINDOW_SIZE_SAMPLES) // WINDOW_STRIDE_SAMPLES  # 49\n",
    "\n",
    "FEATURE_SHAPE = (N_FRAMES, N_MEL_BINS, 1)   # entrada do modelo: (49, 40, 1)\n",
    "print(f'Feature shape: {FEATURE_SHAPE}')\n",
    "\n",
    "BATCH_SIZE = 128\n",
    "EPOCHS = 25\n",
    "LEARNING_RATE = 1e-3"
   ]
  },
  {
