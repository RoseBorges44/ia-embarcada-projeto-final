    "## 9. Export pra C\n",
    "\n",
    "Gera `model_data.c` no formato que o firmware espera. Substitua o arquivo placeholder em `firmware/`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "DzZa9tqRWtkU",
    "outputId": "a52caeba-190b-4ab5-dca6-0ee970073f36"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Arquivos gerados:\n",
      "   model_data.c (45,408 bytes de modelo)\n",
      "   model_data.h\n",
      "\n",
      "🔧 PRÓXIMO PASSO:\n",
      "   Copie esses 2 arquivos pra firmware/ substituindo os placeholders.\n",
      "\n",
      "   Labels (na mesma ordem do firmware):\n",
      "      0: happy\n",
      "      1: yes\n",
      "      2: no\n",
      "      3: stop\n",
      "      4: silence\n",
      "      5: unknown\n"
     ]
    }
   ],
   "source": [
    "def tflite_to_c_array(tflite_bytes, var_name='g_model'):\n",
    "    \"\"\"Gera um arquivo .c com o modelo como uint8_t array alinhado.\n",
    "    Alinhamento de 8 bytes é OBRIGATÓRIO no TFLite Micro.\n",
    "    \"\"\"\n",
    "    lines = [\n",
    "        '// Modelo TFLite quantizado int8',\n",
    "        '// Gerado automaticamente pelo treino_kws.ipynb',\n",
    "        '// NÃO EDITE MANUALMENTE',\n",
    "        '',\n",
    "        '#include \"model_data.h\"',\n",
    "        '',\n",
    "        f'alignas(8) const unsigned char {var_name}[] = {{',\n",
    "    ]\n",
    "    bytes_per_line = 12\n",
    "    for i in range(0, len(tflite_bytes), bytes_per_line):\n",
    "        chunk = tflite_bytes[i:i+bytes_per_line]\n",
    "        lines.append('    ' + ', '.join(f'0x{b:02x}' for b in chunk) + ',')\n",
    "    lines.append('};')\n",
    "    lines.append('')\n",
    "    lines.append(f'const unsigned int {var_name}_len = {len(tflite_bytes)};')\n",
    "    return '\\n'.join(lines)\n",
    "\n",
    "header = f\"\"\"// Header do modelo TFLite quantizado\n",
    "// Gerado automaticamente pelo treino_kws.ipynb\n",
    "\n",
    "#ifndef MODEL_DATA_H_\n",
    "#define MODEL_DATA_H_\n",
    "\n",
    "#include <stdalign.h>\n",
    "\n",
    "#ifdef __cplusplus\n",
    "extern \\\"C\\\" {{\n",
    "#endif\n",
    "\n",
    "extern alignas(8) const unsigned char g_model[];\n",
    "extern const unsigned int g_model_len;\n",
    "\n",
    "// Parâmetros do treino — mantenha sincronizado com firmware/features.h\n",
    "#define MODEL_SAMPLE_RATE       {SAMPLE_RATE}\n",
    "#define MODEL_CLIP_SAMPLES      {CLIP_SAMPLES}\n",
    "#define MODEL_N_MEL_BINS        {N_MEL_BINS}\n",
    "#define MODEL_N_FRAMES          {N_FRAMES}\n",
    "#define MODEL_NUM_CLASSES       {NUM_CLASSES}\n",
    "\n",
    "// Escalas da quantização int8 (do TFLite converter)\n",
    "#define MODEL_INPUT_SCALE       {scale_in}f\n",
    "#define MODEL_INPUT_ZERO_POINT  {zero_in}\n",
    "#define MODEL_OUTPUT_SCALE      {scale_out}f\n",
    "#define MODEL_OUTPUT_ZERO_POINT {zero_out}\n",
    "\n",
    "#ifdef __cplusplus\n",
    "}}\n",
    "#endif\n",
    "\n",
    "#endif  // MODEL_DATA_H_\n",
    "\"\"\"\n",
    "\n",
    "Path('model_data.c').write_text(tflite_to_c_array(tflite_model))\n",
    "Path('model_data.h').write_text(header)\n",
    "\n",
    "print('✅ Arquivos gerados:')\n",
    "print(f'   model_data.c ({len(tflite_model):,} bytes de modelo)')\n",
    "print(f'   model_data.h')\n",
    "print()\n",
    "print('🔧 PRÓXIMO PASSO:')\n",
    "print('   Copie esses 2 arquivos pra firmware/ substituindo os placeholders.')\n",
    "print(f'\\n   Labels (na mesma ordem do firmware):')\n",
    "for i, label in enumerate(LABELS):\n",
    "    print(f'      {i}: {label}')"
   ]
  },
