   "source": [
    "from tensorflow.keras import layers, Model\n",
    "\n",
    "def build_dscnn(input_shape, num_classes, n_filters=64):\n",
    "    inputs = layers.Input(shape=input_shape, name='input')\n",
    "\n",
    "    # Conv inicial 2D\n",
    "    x = layers.Conv2D(n_filters, (10, 4), strides=(2, 2), padding='same', use_bias=False)(inputs)\n",
    "    x = layers.BatchNormalization()(x)\n",
    "    x = layers.ReLU()(x)\n",
    "\n",
    "    # 4 blocos depthwise separable\n",
    "    for _ in range(4):\n",
    "        x = layers.DepthwiseConv2D((3, 3), padding='same', use_bias=False)(x)\n",
    "        x = layers.BatchNormalization()(x)\n",
    "        x = layers.ReLU()(x)\n",
    "        x = layers.Conv2D(n_filters, (1, 1), padding='same', use_bias=False)(x)\n",
    "        x = layers.BatchNormalization()(x)\n",
    "        x = layers.ReLU()(x)\n",
    "\n",
    "    x = layers.GlobalAveragePooling2D()(x)\n",
    "    x = layers.Dropout(0.2)(x)\n",
    "    outputs = layers.Dense(num_classes, activation='softmax', name='output')(x)\n",
    "\n",
    "    return Model(inputs, outputs, name='kws_dscnn')\n",
    "\n",
    "model = build_dscnn(FEATURE_SHAPE, NUM_CLASSES, n_filters=64)\n",
    "model.summary()"
   ]
