  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "js3vGYB2WtkO"
   },
   "outputs": [],
   "source": [
    "target_indices = {DATASET_LABELS.index(w): i for i, w in enumerate(TARGET_WORDS) if w in DATASET_LABELS}\n",
    "silence_idx_ds = DATASET_LABELS.index('_silence_') if '_silence_' in DATASET_LABELS else None\n",
    "\n",
    "SILENCE_IDX = LABELS.index('silence')\n",
    "UNKNOWN_IDX = LABELS.index('unknown')\n",
    "\n",
    "def relabel(example):\n",
    "    \"\"\"Converte label do dataset (0..34) → label final (0..5).\"\"\"\n",
    "    audio = example['audio']\n",
    "    ds_label = example['label']\n",
    "\n",
    "    # tf.py_function pra mapear via Python dict\n",
    "    def py_map(lbl):\n",
    "        lbl = int(lbl.numpy())\n",
    "        if lbl == silence_idx_ds:\n",
    "            return np.int64(SILENCE_IDX)\n",
    "        if lbl in target_indices:\n",
    "            return np.int64(target_indices[lbl])\n",
    "        return np.int64(UNKNOWN_IDX)\n",
    "\n",
    "    new_label = tf.py_function(py_map, [ds_label], tf.int64)\n",
    "    new_label.set_shape([])\n",
    "    return audio, new_label"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "fJhWLs4eWtkP"
   },
   "source": [
    "## 4. Extração de features\n",
    "\n",
    "Mel spectrogram em vez de MFCC completo — é o que o MicroSpeech usa (slide 41 da Aula 6) e ocupa metade da memória."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "ISTkNWrcWtkQ"
   },
   "outputs": [],
   "source": [
    "def audio_to_features(audio):\n",
    "    \"\"\"Áudio bruto (int16) → mel spectrogram log (49, 40, 1).\n",
    "\n",
    "    Esta função TEM QUE produzir exatamente as mesmas features\n",
    "    que firmware/features.c calcula em tempo de inferência.\n",
    "    \"\"\"\n",
    "    # Garante 1 segundo (16 000 amostras) — pad com zero ou trunca\n",
    "    audio = tf.cast(audio, tf.float32) / 32768.0   # int16 → float em [-1, 1]\n",
    "    audio = audio[:CLIP_SAMPLES]\n",
    "    pad = tf.maximum(CLIP_SAMPLES - tf.shape(audio)[0], 0)\n",
    "    audio = tf.pad(audio, [[0, pad]])\n",
    "\n",
    "    # STFT\n",
    "    stft = tf.signal.stft(\n",
    "        audio,\n",
    "        frame_length=WINDOW_SIZE_SAMPLES,\n",
    "        frame_step=WINDOW_STRIDE_SAMPLES,\n",
    "        fft_length=512,\n",
    "        window_fn=tf.signal.hann_window,\n",
    "    )\n",
    "    spectrogram = tf.abs(stft)\n",
    "\n",
    "    # Mel filterbank\n",
    "    num_spectrogram_bins = spectrogram.shape[-1]\n",
    "    linear_to_mel = tf.signal.linear_to_mel_weight_matrix(\n",
    "        num_mel_bins=N_MEL_BINS,\n",
    "        num_spectrogram_bins=num_spectrogram_bins,\n",
    "        sample_rate=SAMPLE_RATE,\n",
    "        lower_edge_hertz=20.0,\n",
    "        upper_edge_hertz=4000.0,\n",
    "    )\n",
    "    mel_spec = tf.tensordot(spectrogram, linear_to_mel, 1)\n",
    "    mel_spec.set_shape(spectrogram.shape[:-1].concatenate(linear_to_mel.shape[-1:]))\n",
    "\n",
    "    # Log (estabilizado)\n",
    "    log_mel = tf.math.log(mel_spec + 1e-6)\n",
    "\n",
    "    # Ajusta pra (N_FRAMES, N_MEL_BINS, 1)\n",
    "    log_mel = log_mel[:N_FRAMES, :]\n",
    "    log_mel = tf.expand_dims(log_mel, -1)\n",
    "\n",
    "    return log_mel\n",
    "\n",
    "def preprocess(example):\n",
    "    audio, label = relabel(example)\n",
    "    features = audio_to_features(audio)\n",
    "    return features, label"
   ]
