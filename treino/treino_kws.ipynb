    "# Carrega Speech Commands v2 (35 palavras)\n",
    "(ds_train, ds_val, ds_test), info = tfds.load(\n",
    "    'speech_commands',\n",
    "    split=['train', 'validation', 'test'],\n",
    "    shuffle_files=False,\n",
    "    as_supervised=False,\n",
    "    with_info=True,\n",
    ")\n",
    "\n",
    "# Lista de labels do dataset (0 a 34, mais _silence_ e _unknown_)\n",
    "DATASET_LABELS = info.features['label'].names\n",
    "print(f'{len(DATASET_LABELS)} labels no dataset original:')\n",
    "print(DATASET_LABELS)"
   ]
